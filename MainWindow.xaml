<Window x:Class="ComicConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comic WebP Converter" Height="850" Width="800" MinHeight="700" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Common Paths -->
            <RowDefinition Height="200"/>  <!-- Items to Process -->
            <RowDefinition Height="Auto"/> <!-- Settings -->
            <RowDefinition Height="Auto"/> <!-- Checkboxes & Modes -->
            <RowDefinition Height="Auto"/> <!-- Start Button & Progress -->
            <RowDefinition Height="*"/>    <!-- Log -->
        </Grid.RowDefinitions>

        <!-- COMMON PATHS -->
        <GroupBox Header="Common Paths" Grid.Row="0" Margin="0,0,0,10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Temp/Target Folder:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtTempFolder" Grid.Row="0" Grid.Column="1" Margin="5" ToolTip="Folder where extraction and conversion happens"/>
                <Button Content="Browse..." Grid.Row="0" Grid.Column="2" Margin="5" Width="75" Click="BtnBrowseTemp_Click"/>

                <TextBlock Text="Final Output Folder:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtFinalFolder" Grid.Row="1" Grid.Column="1" Margin="5" ToolTip="Where the final CBZ files will be copied"/>
                <Button Content="Browse..." Grid.Row="1" Grid.Column="2" Margin="5" Width="75" Click="BtnBrowseFinal_Click"/>

                <TextBlock Text="Fallback 7z.exe (Opt):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="Txt7zPath" Grid.Row="2" Grid.Column="1" Margin="5" ToolTip="Leave empty to use built-in C# SharpCompress"/>
                <Button Content="Browse..." Grid.Row="2" Grid.Column="2" Margin="5" Width="75" Click="BtnBrowse7z_Click"/>
            </Grid>
        </GroupBox>

        <!-- ITEMS TO PROCESS -->
        <GroupBox Header="Items to Process" Grid.Row="1" Margin="0,0,0,10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <ListBox x:Name="LstSourceItems" Margin="5" SelectionMode="Extended"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Content="Add Folder..." Margin="5" Width="90" Click="BtnAddFolder_Click"/>
                    <Button Content="Add File(s)..." Margin="5" Width="90" Click="BtnAddFiles_Click"/>
                    <Button x:Name="BtnRemoveItem" Content="Remove" Margin="5" Width="90" Click="BtnRemoveItem_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- SETTINGS -->
        <GroupBox Header="Conversion Settings" Grid.Row="2" Margin="0,0,0,10" Padding="5">
            <UniformGrid Columns="3">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Threads:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtThreads" Width="50" Text="8" VerticalAlignment="Center" ToolTip="Number of parallel conversions"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Resize:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtResize" Width="60" Text="100%" VerticalAlignment="Center" ToolTip="Image resize (e.g., 100% or 1920x1080)"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Quality (1-100):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtQuality" Width="50" Text="67" VerticalAlignment="Center" ToolTip="WebP Quality level"/>
                </StackPanel>
            </UniformGrid>
        </GroupBox>

        <!-- CHECKBOXES & MODES -->
        <GroupBox Header="Options &amp; Mode" Grid.Row="3" Margin="0,0,0,10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <CheckBox x:Name="ChkDeleteSource" Content="Delete Source if final size is smaller" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkDeleteTemp" Content="Delete Temp Folder at end" IsChecked="True" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkCopyFinal" Content="Copy final zip to Final Output Folder" IsChecked="True" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkTrimPages" Content="Trim pages (remove borders)" IsChecked="True" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkSmartTrimPages" Content="Smart Trim (ignore small elements like page numbers)" ToolTip="Trims borders where ≥97% of pixels match the background, even if a page number interrupts the edge" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkIncludeRange" Content="Include volume/chapter range in name" IsChecked="True" Margin="0,0,0,5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Zip Mode:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <RadioButton x:Name="RbZipSingle" Content="Single (One CBZ for all)" IsChecked="True" Margin="0,0,0,5"/>
                    <RadioButton x:Name="RbZipIndividual" Content="Individual (One CBZ per folder/file)" Margin="0,0,0,5"/>
                    <RadioButton x:Name="RbZipNone" Content="None (Keep folder structure)"/>
                    
                    <TextBlock Text="Trim Settings:" FontWeight="Bold" Margin="0,10,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Min Size (%):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,2,5,2"/>
                        <TextBox x:Name="TxtTrimMinSize" Grid.Row="0" Grid.Column="1" Width="40" HorizontalAlignment="Left" Text="75" Margin="0,2,0,2" ToolTip="Minimum size after trim (default 75)"/>

                        <TextBlock Text="Smart Threshold (%):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,2,5,2"/>
                        <TextBox x:Name="TxtSmartTrimThreshold" Grid.Row="1" Grid.Column="1" Width="40" HorizontalAlignment="Left" Text="97" Margin="0,2,0,2" ToolTip="Percentage of background pixels (default 97)"/>

                        <TextBlock Text="Smart Tolerance (%):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,2,5,2"/>
                        <TextBox x:Name="TxtSmartTrimTolerance" Grid.Row="2" Grid.Column="1" Width="40" HorizontalAlignment="Left" Text="8" Margin="0,2,0,2" ToolTip="Color distance tolerance (default 8)"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- START BUTTON & PROGRESS -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <Button x:Name="BtnStart" Content="START CONVERSION" Height="40" FontSize="16" FontWeight="Bold" Click="BtnStart_Click"/>
            <ProgressBar x:Name="PbOverall" Height="20" Margin="0,10,0,0"/>
            <TextBlock x:Name="TxtStatus" Text="Ready" Margin="0,5,0,0" HorizontalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <!-- LOG -->
        <GroupBox Header="Log" Grid.Row="5" Padding="5">
            <TextBox x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas"/>
        </GroupBox>


    </Grid>
</Window>
